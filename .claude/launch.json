{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "mishka-hub-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/web"],
      "port": 5173
    },
    {
      "name": "mishka-hub-api",
      "runtimeExecutable": "apps/server/.venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8000", "--app-dir", "apps/server"],
      "port": 8000
    }
  ]
}
