# Base URL of the Mishka Hub backend.
# - Local dev:      http://127.0.0.1:8000
# - Via Cloudflare Tunnel (prod on GitHub Pages): https://<your-tunnel>.trycloudflare.com
#   or your named tunnel hostname.
VITE_API_BASE=http://127.0.0.1:8000

# Interim bearer token (docs/API.md closing note) — every backend endpoint
# except /api/health requires this until Phase 4 replaces it with real JWTs.
# Copy the value from apps/server/.env's MISHKA_DEV_TOKEN.
VITE_DEV_TOKEN=
