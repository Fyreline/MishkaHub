# Base URL of the Mishka Hub backend.
# - Local dev:      http://127.0.0.1:8000
# - Via Cloudflare Tunnel (prod on GitHub Pages): https://<your-tunnel-hostname>
VITE_API_BASE=http://127.0.0.1:8000

# No client-side auth secret needed here — login is a real email/password
# form (docs/phases/PHASE-4-accounts-feedback.md) that exchanges credentials
# for a JWT at runtime, not a baked-in token.
