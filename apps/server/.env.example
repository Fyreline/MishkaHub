# Copy this file to `.env` and fill in your TMDB credentials.
# Get a free key at https://www.themoviedb.org/settings/api
#
# Two auth options — you only need ONE:
#   - Preferred: the v4 "API Read Access Token" (a long JWT-looking string).
#   - Or the classic v3 "API Key".
MISHKA_TMDB_READ_TOKEN=
MISHKA_TMDB_API_KEY=

# Household defaults (UK / Scotland).
MISHKA_REGION=GB
MISHKA_LANGUAGE=en-GB

MISHKA_ENVIRONMENT=development
